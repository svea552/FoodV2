// State
let startTag=0, aktWoche=0, activeDay=0;
let auswahl=Array(7).fill(null).map(()=>({f:true,a:true,k:true}));
let vorhanden={};
let aktiveTage=Array(7).fill(true);
let sheetPort=3, sheetBei="A", sheetName="";
let notionStatus="";
let copyLabel="In Zwischenablage kopieren";

function getTage(){
  return Array(7).fill(null).map((_,i)=>({
    wochentag:WL[(startTag+i)%7],
    wtKurz:WK[(startTag+i)%7],
    plan:P[(aktWoche*7+i)%21],
    idx:i
  }));
}

// ── Tabs ──────────────────────────────────────────────────────────────────────
function showTab(t){
  ["plan","rezepte","einkauf"].forEach(id=>{
    document.getElementById("pane-"+id).classList.toggle("on",id===t);
    document.getElementById("tab-"+id).classList.toggle("on",id===t);
    const svgEls=document.querySelectorAll("#tab-"+id+" svg path, #tab-"+id+" svg rect");
    svgEls.forEach(el=>el.setAttribute("stroke",id===t?"#D4522A":"#8E8E93"));
    const fillEls=document.querySelectorAll("#tab-"+id+" svg rect[fill]");
    fillEls.forEach(el=>el.setAttribute("fill",id===t?"#D4522A":"#8E8E93"));
  });
  if(t==="einkauf")renderEinkauf();
  if(t==="rezepte")renderRezepte();
}

// ── Plan ──────────────────────────────────────────────────────────────────────
function naechsteWoche(){
  aktWoche=(aktWoche+1)%3;
  auswahl=Array(7).fill(null).map(()=>({f:true,a:true,k:true}));
  document.getElementById("hdr-sub").textContent="Woche "+(aktWoche+1)+" · 3-Wochen-Rotation";
  activeDay=0;
  renderPlan();
}

function setWoche(i){
  aktWoche=i;
  auswahl=Array(7).fill(null).map(()=>({f:true,a:true,k:true}));
  document.getElementById("hdr-sub").textContent="Woche "+(aktWoche+1)+" · 3-Wochen-Rotation";
  activeDay=0;
  renderPlan();
}

function setStartTag(i){
  startTag=i;
  aktiveTage=Array(7).fill(true);
  activeDay=0;
  renderPlan();
  renderEinkauf();
}

function setActiveDay(i){
  activeDay=i;
  renderDayDetail();
  // Update day strip
  document.querySelectorAll(".day-btn").forEach((btn,idx)=>{
    btn.classList.toggle("on",idx===i);
  });
}

function toggleMeal(idx,typ){
  auswahl[idx][typ]=!auswahl[idx][typ];
  renderDayDetail();
}

function renderPlan(){
  const tage=getTage();
  const p=document.getElementById("pane-plan");

  // Woche selector + day strip + day detail
  let html=`<div style="background:#fff;padding:16px 16px 0;border-bottom:1px solid #E5E5EA">
    <div class="wsel">
      ${[0,1,2].map(i=>`<button class="wbtn${aktWoche===i?" on":""}" onclick="setWoche(${i})">Woche ${i+1}</button>`).join("")}
    </div>
  </div>
  <div class="day-strip">
    ${tage.map(({wtKurz,idx})=>`
      <button class="day-btn${activeDay===idx?" on":""}" onclick="setActiveDay(${idx})">
        <span class="day-lbl">${wtKurz}</span>
        <div class="day-circle">${idx+1}</div>
      </button>`).join("")}
  </div>
  <div class="day-detail" id="day-detail"></div>`;

  p.innerHTML=html;
  renderDayDetail();
}

function renderDayDetail(){
  const tage=getTage();
  const {plan,wochentag}=tage[activeDay];
  const sel=auswahl[activeDay];
  const rz=RZ[plan.k];

  const meals=[
    {typ:"f",label:"Frühstück",name:"Overnight Oats",sub:"~395 kcal · 35g Protein",showRez:true},
    {typ:"a",label:"Mittag",name:plan.a,sub:"oder Reste vom Vorabend",showRez:false},
    {typ:"k",label:"Abendessen",name:plan.k,sub:rz?`${rz.kcal} kcal · ${rz.prot}g Protein`:"",showRez:true}
  ];

  let html=`
    <div class="day-name-row">
      <div class="day-name">${wochentag}</div>
      ${plan.gn?'<span class="genuss-badge">Genuss</span>':""}
    </div>
    ${meals.map(({typ,label,name,sub,showRez})=>`
      <div class="meal-card">
        <div class="meal-inner">
          <div class="meal-left">
            <div class="meal-label">${label}</div>
            <div class="meal-name">${name}</div>
            ${sub?`<div class="meal-sub">${sub}</div>`:""}
          </div>
          <div class="meal-right">
            ${showRez?`<button class="rez-btn" onclick="openSheet('${name.replace(/'/g,"\\'")}')">Rezept</button>`:""}
            <button class="check-circle${sel[typ]?" on":""}" onclick="toggleMeal(${activeDay},'${typ}')"></button>
          </div>
        </div>
      </div>`).join("")}
    <div class="starttag-sec">
      <div class="sec-lbl">Starttag</div>
      <div class="strow">
        ${WK.map((t,i)=>`<button class="stbtn${startTag===i?" on":""}" onclick="setStartTag(${i})">${t}</button>`).join("")}
      </div>
    </div>`;

  document.getElementById("day-detail").innerHTML=html;
}

// ── Rezepte ───────────────────────────────────────────────────────────────────
function renderRezepte(){
  const tage=getTage();
  let html=`
    <div class="pad">
      <div class="wsel">
        ${[0,1,2].map(i=>`<button class="wbtn${aktWoche===i?" on":""}" onclick="setWoche(${i});renderRezepte()">Woche ${i+1}</button>`).join("")}
      </div>
      <div style="font-size:13px;font-weight:600;color:#8E8E93;text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">Täglich</div>
      <div class="oats-card" onclick="openSheet('Overnight Oats')">
        <div>
          <div class="oats-name">Overnight Oats</div>
          <div class="oats-sub">395 kcal · 35g Protein</div>
        </div>
        <span class="oats-arr">›</span>
      </div>
      <div style="font-size:13px;font-weight:600;color:#8E8E93;text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;margin-top:16px">Diese Woche</div>
      <div class="woche-list">
        ${tage.map(({wtKurz,plan,idx})=>{
          const r=RZ[plan.k];
          return`<div class="rz-row" onclick="openSheet('${plan.k.replace(/'/g,"\\'")}')">
            <div class="rz-day-badge${plan.gn?" gn":""}">${wtKurz}</div>
            <div class="rz-info">
              <div class="rz-name">${plan.k}</div>
              ${r?`<div class="rz-meta">${r.kcal} kcal · ${r.prot}g Protein</div>`:""}
            </div>
            <span class="rz-arr">›</span>
          </div>`;
        }).join("")}
      </div>
    </div>`;
  document.getElementById("pane-rezepte").innerHTML=html;
}

// ── Einkauf ───────────────────────────────────────────────────────────────────
function getEinkauf(){
  const tage=getTage();
  const map={};
  tage.forEach(({plan,idx})=>{
    if(!aktiveTage[idx])return;
    const sel=auswahl[idx];
    const add=zs=>zs.forEach(it=>{
      if(!map[it.n])map[it.n]={n:it.n,e:it.e,v:0,c:it.c};
      map[it.n].v+=it.v;
    });
    if(sel.f)add(ZU.oats);
    if(sel.a)add(AUFL[plan.a]||[]);
    if(sel.k){const r=RZ[plan.k];if(r)add(r.beilage?[...r.zuK,...r.zuA]:r.zu);}
  });
  const items=Object.values(map).map(it=>({n:it.n,m:fm(it.c!==null?Math.min(it.v,it.c):it.v,it.e)}));
  const g={};KATS.forEach(k=>g[k]=[]);
  items.forEach(it=>(g[gk(it.n)]||g["Sonstiges"]).push(it));
  return KATS.map(k=>({kat:k,items:g[k].sort((a,b)=>a.n.localeCompare(b.n))})).filter(k=>k.items.length>0);
}

function toggleTag(idx){
  aktiveTage[idx]=!aktiveTage[idx];
  renderEinkauf();
}

function toggleVorhanden(n){
  vorhanden[n]=!vorhanden[n];
  const el=document.getElementById("ek-"+btoa(unescape(encodeURIComponent(n))).replace(/[^a-z0-9]/gi,""));
  if(el){
    el.querySelector(".ek-chk").classList.toggle("on",vorhanden[n]);
    el.querySelector(".ek-name").classList.toggle("done",vorhanden[n]);
  }
  updateProgBar();
}

function updateProgBar(){
  const kats=getEinkauf();
  const alle=kats.flatMap(k=>k.items);
  const ben=alle.filter(it=>!vorhanden[it.n]).length;
  const prog=alle.length>0?((alle.length-ben)/alle.length)*100:0;
  const fill=document.getElementById("prog-fill");
  const bt=document.getElementById("prog-t");
  const bs=document.getElementById("prog-s");
  if(fill)fill.style.width=prog+"%";
  if(bt)bt.textContent=ben+" noch benötigt";
  if(bs)bs.textContent=(alle.length-ben)+" von "+alle.length;
}

function renderEinkauf(){
  const tage=getTage();
  const kats=getEinkauf();
  const alle=kats.flatMap(k=>k.items);
  const ben=alle.filter(it=>!vorhanden[it.n]).length;
  const prog=alle.length>0?((alle.length-ben)/alle.length)*100:0;

  let html=`
    <div class="ek-hdr">
      <div class="sec-lbl">Starttag</div>
      <div class="ek-strow">
        ${WK.map((t,i)=>`<button class="ek-stbtn${startTag===i?" on":""}" onclick="setStartTag(${i})">${t}</button>`).join("")}
      </div>
      <div class="sec-lbl">Einkauf für</div>
      <div style="display:flex;gap:6px">
        ${tage.map(({wtKurz,idx})=>`<button class="ek-tbtn${aktiveTage[idx]?" on":""}" onclick="toggleTag(${idx})">${wtKurz}</button>`).join("")}
      </div>
    </div>
    <div class="prog-wrap">
      <div class="prog-row">
        <span class="prog-t" id="prog-t">${ben} noch benötigt</span>
        <span class="prog-s" id="prog-s">${alle.length-ben} von ${alle.length}</span>
      </div>
      <div class="prog-bar"><div class="prog-fill" id="prog-fill" style="width:${prog}%"></div></div>
    </div>
    <div class="pad">
      ${kats.map(({kat,items})=>`
        <div class="kat-sec">
          <div class="kat-lbl">${kat}</div>
          <div>
            ${items.map(it=>{
              const done=!!vorhanden[it.n];
              const id="ek-"+btoa(unescape(encodeURIComponent(it.n))).replace(/[^a-z0-9]/gi,"");
              return`<div class="ek-item" id="${id}" onclick="toggleVorhanden('${it.n.replace(/'/g,"\\'")}')">
                <div class="ek-chk${done?" on":""}"></div>
                <span class="ek-name${done?" done":""}">${it.n}</span>
                <span class="ek-menge">${it.m}</span>
              </div>`;
            }).join("")}
          </div>
        </div>`).join("")}
      <div class="ek-actions">
        <button class="btn-notion" id="btn-notion" onclick="expNotion()" ${ben===0?"disabled":""}>In Notion speichern</button>
        <button class="btn-copy" id="btn-copy" onclick="doCopy()" ${ben===0?"disabled":""}>${copyLabel}</button>
        <div id="notion-msg"></div>
      </div>
    </div>`;

  document.getElementById("pane-einkauf").innerHTML=html;
}

async function expNotion(){
  const btn=document.getElementById("btn-notion");
  if(!btn||btn.disabled)return;
  btn.disabled=true;btn.textContent="Wird gespeichert…";
  const kats=getEinkauf();
  const heute=new Date().toLocaleDateString("de-DE",{day:"2-digit",month:"2-digit",year:"numeric"});
  const titel="Einkaufsliste "+heute;
  const txt=kats.map(({kat,items})=>{const r=items.filter(it=>!vorhanden[it.n]);if(!r.length)return"";return"**"+kat+"**\n"+r.map(it=>"- [ ] "+it.n+" ("+it.m+")").join("\n");}).filter(Boolean).join("\n\n");
  try{
    const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,system:'Erstelle eine Notion-Unterseite mit dem Titel "'+titel+'" als Unterseite von Page ID 817a3f8e-1b5a-430c-996d-9f7d34a6d0ff. Füge die Einkaufsliste als To-do-Blöcke ein. Antworte nur mit "OK".',messages:[{role:"user",content:titel+"\n\n"+txt}],mcp_servers:[{type:"url",url:"https://mcp.notion.com/mcp",name:"notion-mcp"}]})});
    const d=await res.json();
    const msg=document.getElementById("notion-msg");
    if(d.content&&d.content.length>0){
      btn.textContent="Gespeichert ✓";
      if(msg)msg.innerHTML='<div class="notion-ok">In Notion gespeichert.</div>';
    }else{
      btn.disabled=false;btn.textContent="In Notion speichern";
      if(msg)msg.innerHTML='<div class="notion-err">Fehler. Bitte nochmal versuchen.</div>';
    }
  }catch(e){
    btn.disabled=false;btn.textContent="In Notion speichern";
    const msg=document.getElementById("notion-msg");
    if(msg)msg.innerHTML='<div class="notion-err">Fehler. Bitte nochmal versuchen.</div>';
  }
}

async function doCopy(){
  const kats=getEinkauf();
  const lines=[];
  kats.forEach(({kat,items})=>{
    const r=items.filter(it=>!vorhanden[it.n]);
    if(!r.length)return;
    lines.push(kat);
    r.forEach(it=>lines.push("- "+it.n+" ("+it.m+")"));
    lines.push("");
  });
  try{
    await navigator.clipboard.writeText(lines.join("\n").trim());
    const btn=document.getElementById("btn-copy");
    if(btn){btn.textContent="Kopiert!";setTimeout(()=>{btn.textContent="In Zwischenablage kopieren";},2000);}
  }catch(e){
    const btn=document.getElementById("btn-copy");
    if(btn)btn.textContent="Fehlgeschlagen";
  }
}

// ── Sheet ─────────────────────────────────────────────────────────────────────
function openSheet(name){
  sheetName=name;
  const r=RZ[name];
  if(!r)return;
  sheetPort=r.b;
  sheetBei="A";
  document.getElementById("sh-title").textContent=name;
  document.getElementById("sh-kcal").textContent=r.kcal+" kcal · "+r.prot+"g Protein";
  renderSheetContent();
  document.getElementById("sheet").classList.add("on");
}

function closeSheet(){
  document.getElementById("sheet").classList.remove("on");
}

function changePort(d){
  sheetPort=Math.max(1,Math.min(10,sheetPort+d));
  renderSheetContent();
}

function setBei(v){
  sheetBei=v;
  renderSheetContent();
}

function renderSheetContent(){
  const r=RZ[sheetName];
  if(!r)return;
  const zu=r.beilage?(sheetBei==="B"?[...r.zuK,...r.zuB]:[...r.zuK,...r.zuA]):r.zu;
  const st=r.beilage?[...r.stK,...(sheetBei==="B"?r.stB:r.stA)]:r.st;

  let html=`
    <div class="port-row">
      <span class="port-lbl">Portionen</span>
      <div class="port-ctrl">
        <button class="port-btn" onclick="changePort(-1)">−</button>
        <span class="port-val">${sheetPort}</span>
        <button class="port-btn" onclick="changePort(1)">+</button>
      </div>
    </div>`;

  if(r.beilage){
    html+=`<div class="bei-toggle">
      <button class="bei-btn${sheetBei==="A"?" on":""}" onclick="setBei('A')">Kartoffelbrei</button>
      <button class="bei-btn${sheetBei==="B"?" on":""}" onclick="setBei('B')">Kohlrabi-Bratkartoffeln</button>
    </div>`;
  }

  html+=`<div class="sh-sec-lbl">Zutaten</div>
    <div class="zu-list">
      ${zu.map(it=>`<div class="zu-row"><span>${it.n}</span><span class="zu-menge">${sk(it,sheetPort,r.b)}</span></div>`).join("")}
    </div>
    <div class="sh-sec-lbl">Zubereitung</div>
    <div class="step-list">
      ${st.map((s,i)=>`<div class="step-row"><div class="step-num">${i+1}</div><div class="step-txt">${s}</div></div>`).join("")}
    </div>`;

  document.getElementById("sh-content").innerHTML=html;
}

